# Backend Vercel environment variables
# Isi nilai aslinya di Vercel Dashboard > Project > Settings > Environment Variables.
# Jangan commit file .env.production.local karena berisi secret.

NODE_ENV=production
PORT=5000

# Ganti dengan URL frontend Vercel, contoh:
# FRONTEND_URL=https://nama-project-frontend.vercel.app
FRONTEND_URL=https://ISI-DOMAIN-FRONTEND-VERCEL.vercel.app

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ISI_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=ISI_ANON_KEY
SUPABASE_PUBLISHABLE_KEY=ISI_PUBLISHABLE_KEY
SUPABASE_JWT_SECRET=ISI_JWT_SECRET

# Dipakai script migrasi lokal. Di Vercel boleh ditambahkan juga jika dibutuhkan backend.
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:ISI_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres
